{
  "name": "open-live",
  "version": "0.1.0",
  "description": "Open Live — central orchestration API server",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/main.ts",
    "build": "tsc",
    "start": "node --env-file-if-exists=.env dist/main.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@fastify/websocket": "^11.0.2",
    "fastify": "^5.3.2",
    "fastify-type-provider-zod": "^4.0.2",
    "nano": "^10.1.4",
    "ws": "^8.20.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/nano": "^7.0.0",
    "@types/node": "^22.15.3",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.3"
  }
}
