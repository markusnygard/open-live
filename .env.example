PORT=3000

# CouchDB — credentials
COUCHDB_URL=http://localhost:5984
COUCHDB_USER=admin
COUCHDB_PASSWORD=change-me-before-use

# Strom instance URL
STROM_URL=http://localhost:8080

# STROM_AUTH_MODE controls how STROM_AUTH_TOKEN is used:
#   osc    (default) — token is an OSC PAT, exchanged for a short-lived SAT
#                      via token.svc.prod.osaas.io. Use for OSC-hosted Strom.
#   direct            — token is an API key used directly as a Bearer token.
#                      Use for self-hosted / non-OSC Strom deployments.
STROM_AUTH_MODE=osc
STROM_AUTH_TOKEN=your-token-here

LOG_LEVEL=info
