PORT=3000

# CouchDB — base URL without credentials
COUCHDB_URL=http://localhost:5984
# Optional: if COUCHDB_PASSWORD is set, credentials are injected into the URL at startup.
# If not set, COUCHDB_URL is used as-is (backward compat for URLs with embedded credentials).
COUCHDB_USER=admin
COUCHDB_PASSWORD=change-me-before-use

# Strom instance URL
STROM_URL=http://localhost:8080

# STROM_AUTH_MODE controls how STROM_AUTH_TOKEN is used:
#   osc    (default) — token is an OSC PAT, exchanged for a short-lived SAT
#                      via token.svc.prod.osaas.io. Use for OSC-hosted Strom.
#   direct            — token is an API key used directly as a Bearer token.
#                      Use for self-hosted / non-OSC Strom deployments.
# STROM_TOKEN is supported as a legacy fallback for STROM_AUTH_TOKEN.
STROM_AUTH_MODE=direct
STROM_AUTH_TOKEN=your-token-here

LOG_LEVEL=info

# Optional: static API key for self-hosted deployments not behind OSC's reverse-proxy auth.
# When set, all /api/v1 routes require: Authorization: Bearer <API_KEY>
# Leave unset when running on OSC (auth is handled by the OSC proxy).
# API_KEY=change-me-before-use

# Optional: restrict CORS allowed origins (comma-separated, or * for wildcard).
# Default is * for backward compatibility. Tighten for production deployments.
# CORS_ORIGIN=https://your-studio.example.com

# Optional: set the public base URL so WHIP callback URLs stored in CouchDB point to
# the correct host. Prevents X-Forwarded-Host injection when behind a reverse proxy.
# If not set, the URL is derived from the incoming request (safe only with trustProxy configured).
# PUBLIC_BASE_URL=https://your-open-live-instance.example.com
