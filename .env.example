PORT=3000
COUCHDB_URL=http://admin:password@localhost:5984
COUCHDB_NAME=open-live
CORS_ORIGIN=http://localhost:5173

# Strom instance URL
STROM_URL=http://localhost:8080

# STROM_AUTH_MODE controls how STROM_TOKEN is used:
#   osc    (default) — STROM_TOKEN is an OSC PAT, exchanged for a short-lived SAT
#                      via token.svc.prod.osaas.io. Use for OSC-hosted Strom.
#   direct            — STROM_TOKEN is an API key used directly as a Bearer token.
#                      Use for self-hosted / non-OSC Strom deployments.
STROM_AUTH_MODE=osc
STROM_TOKEN=your-token-here

LOG_LEVEL=info
